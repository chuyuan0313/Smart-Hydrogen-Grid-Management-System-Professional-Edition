// ===== 台電資料快取 (Taipower Cache) =====
struct TaipowerCache {
  bool ever_ok = false;         // 曾成功抓到
  uint32_t last_ok_ms = 0;      // 上次成功抓到的 millis()
  uint32_t last_try_ms = 0;     // 上次嘗試抓取 millis()

  // 9 欄位
  float curr_load = NAN;
  int   curr_util_rate = -1;

  float fore_maxi_sply_capacity = NAN;
  float fore_peak_dema_load = NAN;
  float fore_peak_resv_capacity = NAN;
  float fore_peak_resv_rate = NAN;

  String fore_peak_resv_indicator;
  String fore_peak_hour_range;
  String publish_time;
};
static TaipowerCache g_tp;

// ===== 檔案系統輔助函式 (FS Helper) =====
static void serveFile(const char* path, const char* contentType) {
  if (!LittleFS.exists(path)) { server.send(404, "text/plain", "Not Found"); return; }
  File f = LittleFS.open(path, "r");
  if (!f) { server.send(500, "text/plain", "FS Error"); return; }
  server.streamFile(f, contentType);
  f.close();
}

